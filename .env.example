# Copy to .env and adjust on Vast.ai or a local workstation.

# Project-local metadata manifests. These are used by read-only audit scripts.
WOOD_DC_VSB_MANIFEST=data/processed/large_scale_wood_surface_defects_manifest.jsonl
WOOD_DC_VNWOODKNOT_MANIFEST=data/processed/vnwoodknot_manifest.jsonl

# Vast.ai default YOLO dataset YAML locations. Override these after materializing variants.
WOOD_DC_VSB_BASELINE_DATASET_YAML=/workspace/data/main_dataset/benchmarks/vsb7_3600_rare_first_yolo/dataset.yaml
WOOD_DC_VN_BASELINE_DATASET_YAML=/workspace/data/vnwoodknot/benchmarks/vnwoodknot_live_dead_2class_yolo/dataset.yaml
WOOD_DC_VSB_P1_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/P1_CLAHE_luminance/dataset.yaml
WOOD_DC_VSB_P2_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/P2_illumination_normalization/dataset.yaml
WOOD_DC_VSB_P3_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/P3_mild_unsharp/dataset.yaml
WOOD_DC_VSB_A1_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/A1_defect_preserving_crop/dataset.yaml
WOOD_DC_VSB_A2_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/A2_texture_aware_color_jitter/dataset.yaml
WOOD_DC_VSB_A3_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/A3_copy_paste_defects/dataset.yaml
WOOD_DC_VSB_P4_A4_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vsb/P4_combined_safe__A4_combined_best/dataset.yaml
WOOD_DC_VN_P2_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vnwoodknot/P2_illumination_normalization/dataset.yaml
WOOD_DC_VN_A1_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vnwoodknot/A1_defect_preserving_crop/dataset.yaml
WOOD_DC_VN_P4_A4_DATASET_YAML=/workspace/data/wood_defect_datacentric/generated_yolo/vnwoodknot/P4_combined_safe__A4_combined_best/dataset.yaml

# Training runtime defaults.
CUDA_VISIBLE_DEVICES=0
